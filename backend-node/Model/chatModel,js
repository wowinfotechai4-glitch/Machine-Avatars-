const db = require("../config/db");


// SAVE CHAT
exports.saveChat = async (
  userId,
  question,
  answer
) => {

  const [result] = await db
    .promise()
    .query(

      `
      INSERT INTO tb_chat_history
      (
        user_id,
        question,
        answer
      )

      VALUES (?, ?, ?)
      `,

      [
        userId,
        question,
        answer
      ]

    );

  return result;

};


// GET CHAT HISTORY
exports.getChatHistory = async () => {

  const [rows] = await db
    .promise()
    .query(

      `
      SELECT *
      FROM tb_chat_history
      ORDER BY created_at DESC
      `

    );

  return rows;

};